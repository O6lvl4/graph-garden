{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "Almide",
  "scopeName": "source.almide",
  "fileTypes": ["almd"],
  "patterns": [
    { "include": "#comment" },
    { "include": "#string" },
    { "include": "#number" },
    { "include": "#keyword-control" },
    { "include": "#keyword-declaration" },
    { "include": "#keyword-modifier" },
    { "include": "#keyword-flow" },
    { "include": "#constant" },
    { "include": "#type" },
    { "include": "#function-def" },
    { "include": "#operator" },
    { "include": "#annotation" }
  ],
  "repository": {
    "comment": {
      "match": "//.*$",
      "name": "comment.line.double-slash.almide"
    },
    "string": {
      "patterns": [
        {
          "name": "string.quoted.double.almide",
          "begin": "\"\"\"",
          "end": "\"\"\"",
          "patterns": [{ "include": "#string-interpolation" }]
        },
        {
          "name": "string.quoted.double.almide",
          "begin": "\"",
          "end": "\"",
          "patterns": [
            { "include": "#string-interpolation" },
            { "match": "\\\\.", "name": "constant.character.escape.almide" }
          ]
        }
      ]
    },
    "string-interpolation": {
      "begin": "\\$\\{",
      "end": "\\}",
      "name": "meta.interpolation.almide",
      "beginCaptures": { "0": { "name": "punctuation.definition.interpolation.begin.almide" } },
      "endCaptures": { "0": { "name": "punctuation.definition.interpolation.end.almide" } },
      "patterns": [{ "include": "$self" }]
    },
    "number": {
      "patterns": [
        { "match": "\\b[0-9]+\\.[0-9]+\\b", "name": "constant.numeric.float.almide" },
        { "match": "\\b0x[0-9a-fA-F_]+\\b", "name": "constant.numeric.hex.almide" },
        { "match": "\\b0b[01_]+\\b", "name": "constant.numeric.binary.almide" },
        { "match": "\\b[0-9][0-9_]*\\b", "name": "constant.numeric.integer.almide" }
      ]
    },
    "keyword-control": {
      "match": "\\b(if|then|else|match|for|in|while|guard)\\b",
      "name": "keyword.control.almide"
    },
    "keyword-declaration": {
      "match": "\\b(fn|type|protocol|impl|let|var|test|import|module)\\b",
      "name": "keyword.declaration.almide"
    },
    "keyword-modifier": {
      "match": "\\b(pub|local|mod|effect|strict)\\b",
      "name": "storage.modifier.almide"
    },
    "keyword-flow": {
      "match": "\\b(break|continue|fan)\\b",
      "name": "keyword.control.flow.almide"
    },
    "constant": {
      "match": "\\b(true|false|none|None|some|Some|ok|Ok|err|Err|todo|not|and|or)\\b",
      "name": "constant.language.almide"
    },
    "type": {
      "match": "\\b(Int|Float|String|Bool|Unit|Path|List|Map|Set|Result|Option|Self)\\b",
      "name": "support.type.almide"
    },
    "function-def": {
      "match": "\\b(fn)\\s+([a-zA-Z_][a-zA-Z0-9_]*)(?:\\.([a-zA-Z_][a-zA-Z0-9_]*))?",
      "captures": {
        "1": { "name": "keyword.declaration.almide" },
        "2": { "name": "entity.name.function.almide" },
        "3": { "name": "entity.name.function.almide" }
      }
    },
    "operator": {
      "match": "\\|>|=>|->|\\+\\+|\\.\\.=?|\\.\\.\\.|\\.\\.|[+\\-*/%^]=?|[=!<>]=?|&&|\\|\\||[|]",
      "name": "keyword.operator.almide"
    },
    "annotation": {
      "match": "@[a-zA-Z_][a-zA-Z0-9_]*",
      "name": "entity.other.attribute-name.almide"
    }
  }
}
