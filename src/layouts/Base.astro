---
import '../styles/global.css';
import Header from '../components/Header.astro';
import SearchDialog from '../components/SearchDialog.astro';
import MermaidInit from '../components/MermaidInit.astro';

interface Props {
  title: string;
}

const { title } = Astro.props;
---

<!doctype html>
<html lang="ja">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title} | O6lvl4 Knowledge</title>
    <link rel="icon" type="image/svg+xml" href={`${import.meta.env.BASE_URL.replace(/\/?$/, '/')}favicon.svg`} />
  </head>
  <body>
    <Header />
    <main>
      <slot />
    </main>
    <SearchDialog />
    <MermaidInit />
  </body>
</html>
