---
interface Props {
  links: { id: string; title: string }[];
}

const { links } = Astro.props;
const base = import.meta.env.BASE_URL.replace(/\/?$/, '/');
---

{
  links.length > 0 && (
    <section class="backlinks">
      <h2>Backlinks</h2>
      <ul>
        {links.map((link) => (
          <li>
            <a href={`${base}notes/${link.id}`}>{link.title}</a>
          </li>
        ))}
      </ul>
    </section>
  )
}
