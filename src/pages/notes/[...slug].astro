---
import { getCollection, render } from 'astro:content';
import Base from '../../layouts/Base.astro';
import Backlinks from '../../components/Backlinks.astro';
import LocalGraph from '../../components/LocalGraph.astro';
import { slugify } from '../../lib/slugify';
import { extractWikilinks } from '../../lib/graph';

export async function getStaticPaths() {
  const notes = await getCollection('notes');

  // Build backlinks map
  const backlinkMap = new Map<string, { id: string; title: string }[]>();

  for (const note of notes) {
    if (note.id === 'index') continue; // auto-generated index is not a meaningful backlink
    const links = extractWikilinks(note.body || '');
    for (const link of links) {
      const targetSlug = slugify(link);
      if (!backlinkMap.has(targetSlug)) {
        backlinkMap.set(targetSlug, []);
      }
      backlinkMap.get(targetSlug)!.push({
        id: slugify(note.id),
        title: note.data.title || note.id,
      });
    }
  }

  return notes
    .filter((note) => note.id !== 'index' && note.data.public !== false)
    .map((note) => ({
      params: { slug: slugify(note.id) },
      props: {
        note,
        backlinks: backlinkMap.get(slugify(note.id)) || [],
      },
    }));
}

const { note, backlinks } = Astro.props;
const { Content } = await render(note);
const title = note.data.title || note.id;
const base = import.meta.env.BASE_URL.replace(/\/?$/, '/');

// Extract first paragraph from body as OGP description
function extractDescription(body: string | undefined): string | undefined {
  if (!body) return undefined;
  const withoutFm = body.replace(/^---[\s\S]*?---\s*/, '');
  const lines = withoutFm.split('\n');
  const paragraphs: string[] = [];
  for (const line of lines) {
    const trimmed = line.trim();
    if (trimmed === '' && paragraphs.length > 0) break;
    if (trimmed.startsWith('#') || trimmed.startsWith('```') || trimmed === '') continue;
    paragraphs.push(trimmed);
  }
  if (paragraphs.length === 0) return undefined;
  const text = paragraphs.join(' ').replace(/\[([^\]]*)\]\([^)]*\)/g, '$1').replace(/\[\[([^\]|]*)\|?([^\]]*)\]\]/g, (_, a, b) => b || a).replace(/[*_`#]/g, '');
  return text.length > 200 ? text.slice(0, 197) + '...' : text;
}
const description = extractDescription(note.body);
---

<Base title={title} description={description} canonicalPath={`/notes/${slugify(note.id)}`}>
  <article>
    <h1>{title}</h1>
    {
      note.data.tags && note.data.tags.length > 0 && (
        <div class="note-tags">
          {note.data.tags.map((tag: string) => (
            <a href={`${base}tags/${tag}`} class="tag">{tag}</a>
          ))}
        </div>
      )
    }
    <Content />
  </article>
  <LocalGraph slug={slugify(note.id)} />
  <Backlinks links={backlinks} />
</Base>
