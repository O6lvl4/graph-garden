---
import { getCollection } from 'astro:content';
import Base from '../../layouts/Base.astro';
import { slugify } from '../../lib/slugify';

const base = import.meta.env.BASE_URL.replace(/\/?$/, '/');

export async function getStaticPaths() {
  const notes = await getCollection('notes', ({ data }) => data.public !== false);
  const base = import.meta.env.BASE_URL.replace(/\/?$/, '/');

  // Collect all tags
  const tagMap = new Map<string, typeof notes>();
  for (const note of notes) {
    for (const tag of note.data.tags || []) {
      if (!tagMap.has(tag)) tagMap.set(tag, []);
      tagMap.get(tag)!.push(note);
    }
  }

  return [...tagMap.entries()].map(([tag, notes]) => ({
    params: { tag },
    props: { tag, notes },
  }));
}

const { tag, notes } = Astro.props;
const sorted = notes.sort((a: any, b: any) => {
  const ta = a.data.title || a.id;
  const tb = b.data.title || b.id;
  return ta.localeCompare(tb);
});
---

<Base title={`#${tag}`}>
  <div class="note-list">
    <h1>
      <a href={`${base}tags`} class="back-link">&larr; Tags</a>
      #{tag}
    </h1>
    <p class="tag-count">{notes.length} notes</p>
    {
      sorted.map((note: any) => (
        <a href={`${base}notes/${slugify(note.id)}`} class="note-card">
          <span class="title">{note.data.title || note.id}</span>
          <span class="meta">
            {(note.data.tags || []).map((t: string) => (
              <span class="tag">{t}</span>
            ))}
          </span>
        </a>
      ))
    }
  </div>
</Base>

<style>
  .back-link {
    font-size: 0.9rem;
    color: var(--text-muted);
    margin-right: 0.75rem;
    font-weight: 400;
  }
  .back-link:hover {
    color: var(--text-primary);
    text-decoration: none;
  }
  .tag-count {
    color: var(--text-muted);
    margin-bottom: 1.5rem;
  }
</style>
